<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aicsp.user.mapper.PermissionMapper">
    <sql id="BaseColumns">id,permission_code,permission_name,created_by,created_at,updated_by,updated_at,deleted</sql>
    <select id="selectAll" resultType="com.aicsp.user.entity.Permission">
        SELECT <include refid="BaseColumns" /> FROM cs_permission WHERE deleted = FALSE ORDER BY id
    </select>
</mapper>
