# =========================
# AICSP Python 引擎层配置
# 复制为 .env 后生效；不要把真实 .env 提交到仓库。
# =========================

# 当前运行环境。可选值建议：dev / test / prod。
AICSP_APP_ENV=dev

# stream-service 调用 /api/chat/stream 时携带的内部鉴权 token。
# 需与 stream-service 的 python.engine.internal-token 保持一致。
AICSP_STREAM_INTERNAL_TOKEN=dev-stream-internal-token

# biz-service 调用 /internal/rag/** 时携带的内部鉴权 token。
# 需与 biz-service 调用 Python 引擎的配置保持一致。
AICSP_BIZ_INTERNAL_TOKEN=dev-biz-internal-token

# biz-service 内网地址。后续用于获取权威 RAG 检索过滤条件、提交消息完成事件等。
AICSP_BIZ_BASE_URL=http://localhost:8082

# 是否在聊天回答完成后回调 biz-service /internal/chat/message-completed 持久化消息。
# 本地单独调试 Python 且未启动 biz-service 时可设为 false。
AICSP_MESSAGE_COMPLETED_CALLBACK_ENABLED=true

# =========================
# 本地 Ollama OpenAI 兼容大模型配置
# =========================

# 是否启用真实大模型调用。false 时 /api/chat/stream 返回占位流，便于无模型环境启动。
AICSP_LLM_ENABLED=true

# Ollama OpenAI 兼容接口地址，必须包含 /v1。
AICSP_LLM_BASE_URL=http://localhost:11434/v1

# Ollama 本地模式可填写任意非空值。
AICSP_LLM_API_KEY=ollama

# 智能客服大语言模型名称，由本地 Ollama 提供。
AICSP_LLM_MODEL=gemma4:26b

# 生成温度。客服场景建议偏低，降低发散。
AICSP_LLM_TEMPERATURE=0.2

# 单次回答最大输出 token。
AICSP_LLM_MAX_TOKENS=2048

# 单次模型流式调用超时时间，单位：秒。需小于 Java stream-service 的响应超时。
AICSP_LLM_TIMEOUT_SECONDS=300

# =========================
# 本地 Ollama OpenAI 兼容 Embedding 配置
# =========================

# Embedding OpenAI 兼容接口地址，通常与 LLM 使用同一个 Ollama /v1。
AICSP_EMBEDDING_BASE_URL=http://localhost:11434/v1

# Ollama 本地模式可填写任意非空值。
AICSP_EMBEDDING_API_KEY=ollama

# 知识库向量化模型名称。
AICSP_EMBEDDING_MODEL=qwen3-embedding:8b

# qwen3-embedding:8b 经本地 Ollama 实测返回 4096 维。若更换模型，需重新检测并同步修改 SQL 中 vector(N)。
AICSP_EMBEDDING_DIMENSIONS=4096

# Embedding 请求超时时间，单位：秒。
AICSP_EMBEDDING_TIMEOUT_SECONDS=120

# =========================
# PostgreSQL / pgvector 配置
# =========================

# 是否启用 PostgreSQL 向量检索。false 时 retrieve 返回 vector_store_disabled。
AICSP_VECTOR_STORE_ENABLED=true

# Python 引擎专用数据库连接串。数据库和 schema 请先执行 sql/ 下脚本手动创建。
AICSP_POSTGRES_DSN=postgresql://engine_service:engine_service@localhost:5432/aicsp_engine

# Python 引擎使用的 PostgreSQL schema。
AICSP_POSTGRES_SCHEMA=engine_service

# chunk 元数据与正文表名。
AICSP_POSTGRES_CHUNK_TABLE=engine_chunk

# embedding 向量表名。
AICSP_POSTGRES_EMBEDDING_TABLE=engine_embedding

# 默认召回条数。
AICSP_RETRIEVAL_TOP_K_DEFAULT=8

# 单次召回最大条数，防止内部测试接口误传过大 topK。
AICSP_RETRIEVAL_TOP_K_MAX=50

# 入库时每批调用 embedding 的 chunk 数。模型显存较小时可调小。
AICSP_INGESTION_EMBEDDING_BATCH_SIZE=16

# 入库任务是否在后台执行。true 表示 HTTP 快速返回 SUBMITTED，后台继续处理。
AICSP_INGESTION_BACKGROUND_ENABLED=true

# 是否允许开发环境从 objectPath 指向的本地文件读取原文。
# 生产环境建议关闭，改为接入对象存储读取器。
AICSP_ALLOW_LOCAL_OBJECT_PATH=true

# =========================
# Redis 配置（预留）
# =========================

# Redis 目前仅作为后续缓存/短期状态预留，第一阶段不强制依赖。
AICSP_REDIS_URL=redis://localhost:6379/3

# =========================
# MinIO / 对象存储配置（入库读取原始文件）
# =========================

# 是否启用 MinIO 对象读取。启用后 objectPath 可使用 bucket/object-key 或 minio://bucket/object-key。
AICSP_MINIO_ENABLED=false

# MinIO 服务地址，不包含协议时由 AICSP_MINIO_SECURE 控制 http/https。
AICSP_MINIO_ENDPOINT=localhost:9000

# MinIO Access Key。
AICSP_MINIO_ACCESS_KEY=minioadmin

# MinIO Secret Key。
AICSP_MINIO_SECRET_KEY=minioadmin

# 默认 bucket。objectPath 不包含 bucket 时使用该 bucket。
AICSP_MINIO_BUCKET=aicsp-knowledge

# 是否使用 HTTPS 连接 MinIO。
AICSP_MINIO_SECURE=false
